# Copy this file to .streamlit/secrets.toml and fill in your real values.
# On Streamlit Cloud, paste this content into App Settings → Secrets.
# NEVER commit secrets.toml to version control.

# Anthropic API key (required for asset generation)
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# Google Ads API credentials (required for pushing assets)
[google_ads]
developer_token   = "XXXXXXXXXXXXXXXX"
client_id         = "XXXXXXXX.apps.googleusercontent.com"
client_secret     = "XXXXXXXX"
refresh_token     = "1//XXXXXXXX"
login_customer_id = "XXXXXXXXXX"    # MCC account ID — digits only, no dashes

# Client account names (optional — for display purposes only)
# Keys must be digit-only account IDs (no dashes)
[accounts]
"1234567890" = "Brand A - UK"
"0987654321" = "Brand B - DE"
